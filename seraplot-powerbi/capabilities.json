{
    "dataRoles": [
        {
            "displayName": "Category / Labels",
            "name": "category",
            "kind": "Grouping"
        },
        {
            "displayName": "Values",
            "name": "measure",
            "kind": "Measure"
        },
        {
            "displayName": "Y (scatter only)",
            "name": "measure2",
            "kind": "Measure"
        }
    ],
    "objects": {
        "chartSettings": {
            "properties": {
                "chartType": {
                    "type": {
                        "enumeration": [
                            { "value": "bar", "displayName": "Bar" },
                            { "value": "line", "displayName": "Line" },
                            { "value": "pie", "displayName": "Pie" },
                            { "value": "area", "displayName": "Area" },
                            { "value": "histogram", "displayName": "Histogram" },
                            { "value": "scatter", "displayName": "Scatter" }
                        ]
                    }
                },
                "backgroundColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "categorical": {
                "categories": {
                    "for": {
                        "in": "category"
                    },
                    "dataReductionAlgorithm": {
                        "top": {}
                    }
                },
                "values": {
                    "select": [
                        { "bind": { "to": "measure" } },
                        { "bind": { "to": "measure2" } }
                    ]
                }
            }
        }
    ],
    "privileges": [
        {
            "name": "WebAccess",
            "essential": true,
            "parameters": [
                "https://feur25.github.io/Sera/docs/theme/seraplot_bg.wasm",
                "https://feur25.github.io/Sera/docs/theme/seraplot-web.20260720.js"
            ]
        }
    ]
}
